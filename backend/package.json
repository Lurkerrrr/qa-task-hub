{
  "name": "qa-task-manager-backend",
  "version": "1.0.0",
  "description": "Backend API for QA Task Manager",
  "main": "server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:api": "newman run ../postman/collections/auth.collection.json -e ../postman/environments/local.env.json --export-environment ../postman/environments/ci-env.json && newman run ../postman/collections/bug.collection.json -e ../postman/environments/ci-env.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "allure-commandline": "^2.37.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.2.0",
    "newman": "^6.2.2",
    "newman-reporter-allure": "^3.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
