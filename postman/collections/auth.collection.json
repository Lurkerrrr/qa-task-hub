{
    "info": {
        "_postman_id": "auth-qa-suite-001",
        "name": "Auth API Tests",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Register User",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201 or 400 (if exists)\", function () {",
                            "    pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Postman QA\",\n    \"email\": \"postmanqa@test.com\",\n    \"password\": \"password123\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/auth/register",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "auth",
                        "register"
                    ]
                }
            }
        },
        {
            "name": "Login & Store Token",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.expect(pm.response.code).to.be.equal(200);",
                            "});",
                            "",
                            "pm.test(\"Extract Auth and CSRF Tokens\", function () {",
                            "    var cookies = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie');",
                            "    cookies.forEach(c => {",
                            "        if (c.value.includes('token=')) {",
                            "            var token = c.value.split('token=')[1].split(';')[0];",
                            "            pm.environment.set(\"token\", token);",
                            "        }",
                            "        if (c.value.includes('csrf_token=')) {",
                            "            var csrfToken = c.value.split('csrf_token=')[1].split(';')[0];",
                            "            pm.environment.set(\"csrf_token\", csrfToken);",
                            "        }",
                            "    });",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"postmanqa@test.com\",\n    \"password\": \"password123\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/auth/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "auth",
                        "login"
                    ]
                }
            }
        }
    ]
}