{
    "info": {
        "_postman_id": "bug-qa-suite-002",
        "name": "Bug API Tests (CRUD)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Create New Bug",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "pm.test(\"Extract and save Bug ID\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.data.bug).to.have.property('id');",
                            "    pm.environment.set(\"currentBugId\", jsonData.data.bug.id);",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Cookie",
                        "value": "token={{token}}; csrf_token={{csrf_token}}"
                    },
                    {
                        "key": "x-xsrf-token",
                        "value": "{{csrf_token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"Newman Automated Bug\",\n    \"priority\": \"High\",\n    \"severity\": \"Major\",\n    \"status\": \"Open\",\n    \"assignee\": \"Postman QA\",\n    \"date\": \"2026-03-25\",\n    \"steps\": \"1. Run Newman\\n2. Observe bug creation\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/bugs",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "bugs"
                    ]
                }
            }
        },
        {
            "name": "2. Get Specific Bug",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Bug title matches creation data\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.data.bug.title).to.eql(\"Newman Automated Bug\");",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Cookie",
                        "value": "token={{token}}; csrf_token={{csrf_token}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/bugs/{{currentBugId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "bugs",
                        "{{currentBugId}}"
                    ]
                }
            }
        },
        {
            "name": "3. Update Bug Status",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Success message returned\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.data.message).to.eql('Bug status updated successfully');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Cookie",
                        "value": "token={{token}}; csrf_token={{csrf_token}}"
                    },
                    {
                        "key": "x-xsrf-token",
                        "value": "{{csrf_token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"status\": \"In Progress\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/bugs/{{currentBugId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "bugs",
                        "{{currentBugId}}"
                    ]
                }
            }
        },
        {
            "name": "4. Delete Bug",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Success message returned\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.data.message).to.eql('Bug deleted successfully');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "DELETE",
                "header": [
                    {
                        "key": "Cookie",
                        "value": "token={{token}}; csrf_token={{csrf_token}}"
                    },
                    {
                        "key": "x-xsrf-token",
                        "value": "{{csrf_token}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/bugs/{{currentBugId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "bugs",
                        "{{currentBugId}}"
                    ]
                }
            }
        },
        {
            "name": "5. Verify Deletion (Negative)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 404\", function () {",
                            "    pm.response.to.have.status(404);",
                            "});",
                            "",
                            "pm.test(\"Error message confirms bug is missing\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.message).to.include(\"not found\");",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Cookie",
                        "value": "token={{token}}; csrf_token={{csrf_token}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/bugs/{{currentBugId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "bugs",
                        "{{currentBugId}}"
                    ]
                }
            }
        }
    ]
}