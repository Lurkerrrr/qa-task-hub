{
    "info": {
        "_postman_id": "bug-qa-suite-002",
        "name": "Bug API Tests",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get All Bugs",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "pm.test(\"Bugs array is present\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.data.bugs).to.be.an('array');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/bugs",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "bugs"
                    ]
                }
            }
        }
    ]
}